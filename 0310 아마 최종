    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700;900&family=Nunito:wght@700;900&family=Plus+Jakarta+Sans:wght@300;400;600&family=Outfit:wght@300;400&display=swap" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { margin:0; padding:0; background:#F0EAE7; color:#131313; font-family:'DM Sans',sans-serif; -webkit-font-smoothing:antialiased; min-height:100vh; }
        button { cursor:pointer; border:none; transition:all 0.2s; background:none; }

        /* ── 뒤로 버튼 ── */
        .back-btn { color:#666; border:1px solid #ccc; padding:8px 18px; border-radius:20px; font-size:13px; font-weight:500; margin-bottom:28px; display:inline-block; }
        .back-btn:hover { color:#131313; border-color:#131313; }

        /* ── 스플래시 ── */
        .splash { display:flex; flex-direction:column; align-items:center; justify-content:center; height:70vh; animation:fadeSplash 2s ease-in-out forwards; }
        @keyframes fadeSplash { 0%{opacity:0;transform:translateY(10px)} 20%{opacity:1;transform:translateY(0)} 80%{opacity:1;transform:translateY(0)} 100%{opacity:0;transform:translateY(-10px)} }

        /* ── 무드 카드 ── */
        .mood-grid { display:flex; flex-direction:column; align-items:center; gap:20px; }
        .mood-row  { display:flex; gap:18px; justify-content:center; }
        .mood-card { width:155px; height:155px; border-radius:30px; display:flex; align-items:center; justify-content:center; overflow:hidden; position:relative; box-shadow:0 8px 24px rgba(0,0,0,0.13); }
        .mood-card::before { content:''; position:absolute; inset:0; background:rgba(255,255,255,0.4); opacity:0; transition:opacity 0.15s; }
        .mood-card:hover { transform:translateY(-6px) scale(1.05); box-shadow:0 18px 40px rgba(0,0,0,0.22); }
        .mood-card:hover::before { opacity:1; }
        .mood-card img { width:40px; height:40px; object-fit:contain; pointer-events:none; filter:drop-shadow(0 4px 10px rgba(0,0,0,0.2)); position:relative; z-index:1; }

        /* ── 군집 카드 ── */
        .cluster-card { background:#fff; border:2px solid #E5DED9; border-radius:20px; padding:22px 18px 20px; display:flex; flex-direction:column; gap:12px; text-align:left; width:100%; overflow:visible; }
        .cluster-card:hover { transform:translateY(-5px); }

        /* ── 해시태그 한 줄 ── */
        .tag-row { display:flex; gap:6px; flex-wrap:nowrap; overflow:hidden; }
        .hashtag { font-size:13px; font-weight:800; white-space:nowrap; }

        /* ── 피처 바 ── */
        .feat-bars { display:flex; flex-direction:column; gap:6px; }
        .feat-row  { display:flex; flex-direction:column; gap:2px; }
        .feat-head { display:flex; justify-content:space-between; font-size:11px; }
        .feat-name { font-weight:700; color:#999; }
        .feat-val  { font-weight:800; }
        .feat-bg   { height:4px; border-radius:4px; background:#EBEBEB; overflow:hidden; }
        .feat-fill { height:100%; border-radius:4px; }

        /* ── 로고 ── */
        .logo-wrap { display:flex; align-items:center; gap:14px; }
        .circles-icon { position:relative; width:80px; height:56px; flex-shrink:0; }
        .ci { position:absolute; width:46px; height:46px; border-radius:50%; }
        .ci1 { left:0; top:5px; background:linear-gradient(135deg,#f093fb,#c471ed); opacity:.85; animation:ml 4s ease-in-out infinite; }
        .ci2 { left:18px; top:5px; background:linear-gradient(135deg,#c471ed,#9f7aea); opacity:.6; animation:mc 4s ease-in-out infinite; }
        .ci3 { left:36px; top:5px; background:linear-gradient(135deg,#9f7aea,#667eea); opacity:.5; animation:mr 4s ease-in-out infinite; }
        @keyframes ml{0%,15%{transform:translateX(0);opacity:.85}55%,70%{transform:translateX(18px);opacity:.5}100%{transform:translateX(0);opacity:.85}}
        @keyframes mc{0%,15%{opacity:.6}55%,70%{opacity:.75}100%{opacity:.6}}
        @keyframes mr{0%,15%{transform:translateX(0);opacity:.5}55%,70%{transform:translateX(-18px);opacity:.45}100%{transform:translateX(0);opacity:.5}}
        .logo-text { display:flex; flex-direction:column; gap:0px; }
        .logo-name { font-family:'Plus Jakarta Sans',sans-serif; font-weight:600; font-size:26px; letter-spacing:.02em; color:#1a1a1a; line-height:1.1; }
        .logo-sub  { font-family:'Plus Jakarta Sans',sans-serif; font-weight:300; font-size:10px; letter-spacing:.45em; text-transform:uppercase; color:#aaa; margin-top:3px; }

        /* ── 중앙 정렬 화면 (취향·시드) ── */
        .center-screen { display:flex; flex-direction:column; align-items:center; text-align:center; padding:20px 0 60px; }
        .center-title  { font-family:'DM Sans',sans-serif; font-size:clamp(24px,3.5vw,36px); font-weight:900; color:#131313; margin:0 0 10px; line-height:1.25; letter-spacing:-0.3px; }
        .center-sub    { color:#999; font-size:14px; margin:0 0 44px; }
        .center-opts   { display:flex; flex-direction:column; gap:12px; width:100%; max-width:460px; }

        /* ── 취향 선택 버튼 ── */
        .q-btn { border:1.5px solid #DDD; border-radius:16px; padding:20px 24px; color:#131313; font-size:15px; font-weight:600; text-align:left; background:#fff; display:flex; align-items:center; gap:14px; }
        .q-btn:hover { transform:translateX(4px); }
        .q-icon { width:36px; height:36px; border-radius:10px; display:flex; align-items:center; justify-content:center; font-size:15px; font-weight:900; flex-shrink:0; }

        /* ── 시드 버튼 ── */
        .seed-btn { border:1.5px solid #DDD; border-radius:16px; padding:22px 24px; background:#fff; display:flex; flex-direction:column; gap:4px; text-align:left; width:100%; }
        .seed-btn:hover { transform:translateX(4px); }
        .seed-label  { font-size:16px; font-weight:700; letter-spacing:0; text-transform:none; }
        .seed-name   { font-size:14px; font-weight:600; margin-top:8px; color:#555; }
        .seed-artist { font-size:13px; color:#999; margin-top:2px; }

        /* ── 플레이리스트 (퍼플 고정) ── */
        .pl-bar-bg   { background:#EBEBEB; height:5px; border-radius:5px; overflow:hidden; }
        .pl-bar-fill { height:100%; border-radius:5px; background:linear-gradient(90deg,#9f7aea88,#9f7aea); }
    </style>
