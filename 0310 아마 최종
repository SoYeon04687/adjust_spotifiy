const FEAT_Q     = {danceability:{hi:"리드미컬하고 춤추기 좋은 곡",lo:"리듬감이 적고 차분한 곡"},energy:{hi:"에너지가 넘치고 강렬한 곡",lo:"에너지가 낮고 잔잔한 곡"},valence:{hi:"더 밝고 긍정적인 곡",lo:"더 감성적이고 진지한 곡"},tempo:{hi:"템포가 빠른 곡",lo:"템포가 느린 곡"},acousticness:{hi:"어쿠스틱 악기 중심의 곡",lo:"전자음이 섞인 곡"},instrumentalness:{hi:"보컬이 없는 연주 중심 곡",lo:"보컬이 포함된 곡"}};

/* ── 레이더 차트 ── */
function RadarChart({ means, accent, size=140 }) {
    const pad=22, inner=size-pad*2;
    const n=ALL_FEATS.length,cx=size/2,cy=size/2,r=inner*0.42;
    const maxV={danceability:1,energy:1,valence:1,tempo:200,acousticness:1,instrumentalness:1};
    const ang=i=>(Math.PI*2*i/n)-Math.PI/2;
    const pt=(v,i,rad)=>[cx+rad*Math.cos(ang(i))*v,cy+rad*Math.sin(ang(i))*v];
    const webs=[0.33,0.66,1].map(lv=>ALL_FEATS.map((_,i)=>pt(1,i,r*lv)).map((p,j)=>(j===0?'M':'')+p[0].toFixed(1)+','+p[1].toFixed(1)).join('L')+'Z');
    const dpts=ALL_FEATS.map((k,i)=>pt(Math.min((means[k]||0)/maxV[k],1),i,r));
    const dpath=dpts.map((p,j)=>(j===0?'M':'')+p[0].toFixed(1)+','+p[1].toFixed(1)).join('L')+'Z';
    const gid='rg'+accent.replace('#','');
    return (
        <svg width={size} height={size} viewBox={`0 0 ${size} ${size}`} overflow="visible">
            <defs><radialGradient id={gid} cx="50%" cy="50%" r="50%"><stop offset="0%" stopColor={accent} stopOpacity="0.3"/><stop offset="100%" stopColor={accent} stopOpacity="0.02"/></radialGradient></defs>
            {webs.map((p,i)=><path key={i} d={p} fill="none" stroke="rgba(0,0,0,0.09)" strokeWidth="0.8"/>)}
            {ALL_FEATS.map((_,i)=>{const[x,y]=pt(1,i,r);return <line key={i} x1={cx} y1={cy} x2={x} y2={y} stroke="rgba(0,0,0,0.07)" strokeWidth="0.8"/>;})}
            <path d={dpath} fill={`url(#${gid})`} stroke={accent} strokeWidth="2" strokeLinejoin="round"/>
            {dpts.map((p,i)=><circle key={i} cx={p[0]} cy={p[1]} r="2.5" fill={accent} opacity="0.85"/>)}
            {ALL_FEATS.map((k,i)=>{const[x,y]=pt(1.5,i,r);return <text key={i} x={x} y={y} textAnchor="middle" dominantBaseline="middle" fontSize="7" fill="#aaa" fontFamily="DM Sans,sans-serif" fontWeight="700">{FEAT_LABEL[k]}</text>;})}
        </svg>
    );
}

/* ── 피처 바 ── */
function FeatBars({ means, accent }) {
    const max={danceability:1,energy:1,valence:1,tempo:200,acousticness:1,instrumentalness:1};
    return (
        <div className="feat-bars">
            {ALL_FEATS.map(k=>{
                const pct=Math.min(((means[k]||0)/max[k])*100,100);
                return (
                    <div key={k} className="feat-row">
                        <div className="feat-head">
                            <span className="feat-name">{FEAT_LABEL[k]}</span>
                            <span className="feat-val" style={{color:accent}}>{pct.toFixed(0)}%</span>
                        </div>
                        <div className="feat-bg"><div className="feat-fill" style={{width:`${pct}%`,background:`linear-gradient(90deg,${accent}77,${accent})`}}/></div>
                    </div>
                );
            })}
        </div>
    );
}

/* ══ 메인 앱 ══ */
function App() {
    const [step,setStep]=useState(-1);
    const [mood,setMood]=useState(null);
    const [clusterId,setCId]=useState(null);
    const [side,setSide]=useState(null);
    const [playlist,setPlaylist]=useState([]);
    const [nowPlaying,setNow]=useState(0);
    const [hovCard,setHovCard]=useState(null);

    useEffect(()=>{
        if(step===-1){const t=setTimeout(()=>setStep(0),2000);return()=>clearTimeout(t);}
    },[step]);

    const accent = mood ? MOOD_ACCENT[mood] : PURPLE;
    const clusters = mood ? Object.values(MOOD_DATA[mood]) : [];
    const qFeat = (mood&&clusterId!==null) ? CLUSTER_FEATURE[mood][clusterId] : null;

    /* ── side가 결정된 후 seed 미리보기 (step 3용) ── */
    let popSeed=["","",""],simSeed=["","",""];
    if(mood&&clusterId!==null&&side){
        const cl=Object.values(MOOD_DATA[mood]).find(c=>c.id===clusterId);
        const hilo=side==='high'?'hi':'lo';
        const popList=(cl.playlists&&cl.playlists[hilo]&&cl.playlists[hilo].pop)||[];
        const simList=(cl.playlists&&cl.playlists[hilo]&&cl.playlists[hilo].sim)||[];
        popSeed=popList[0]||["","",""];
        simSeed=simList[0]||["","",""];
    }

    const generatePlaylist=(pref)=>{
        const cl=Object.values(MOOD_DATA[mood]).find(c=>c.id===clusterId);
        const hilo=side==='high'?'hi':'lo';
        /* 신형 구조: playlists[hi|lo][pop|sim] = [[name,artist,id,sim], ...] */
        const prefKey=pref==='pop'?'pop':'sim';
        const raw=((cl.playlists&&cl.playlists[hilo]&&cl.playlists[hilo][prefKey])||[])
            .map(t=>({track_name:t[0],artists:t[1],track_id:t[2],similarity:t[3]??100}));
        if(raw.length===0){setPlaylist([]);setNow(0);setStep(4);return;}
        const seed={...raw[0],similarity:100};
        const pool=raw.slice(1);
        setPlaylist([seed,...pool]);setNow(0);setStep(4);
    };

    /* 호버 이벤트 헬퍼 */
    const hoverOn=(el,color)=>{el.style.borderColor=color;el.style.boxShadow=`0 8px 28px ${color}30, 0 0 0 2px ${color}44`;}
    const hoverOff=(el)=>{el.style.borderColor='#E5DED9';el.style.boxShadow='0 2px 8px rgba(0,0,0,0.05)';}

    return (
        <div style={{maxWidth:960,margin:"0 auto",padding:"40px 20px"}}>

            {/* ── 스플래시 ── */}
            {step===-1 && (
                <div className="splash">
                    <h2 style={{fontSize:"3rem",fontWeight:900,margin:0}}>오늘의 MOOD</h2>
                    <h2 style={{fontSize:"3rem",fontWeight:900,margin:0}}>오늘의 Playlist</h2>
                </div>
            )}

            {step>=0 && (<>

                {/* ── 헤더 ── */}
                <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:32}}>
                    <div className="logo-wrap">
                        <div className="circles-icon">
                            <div className="ci ci1"/><div className="ci ci2"/><div className="ci ci3"/>
                        </div>
                        <div className="logo-text">
                            <span className="logo-name">ENSEMBLE</span>
                            <span className="logo-sub">TEAM PROJECT</span>
                        </div>
                    </div>
                    {step===4 && (
                        <button onClick={()=>{setStep(0);setMood(null);setCId(null);setSide(null);}}
                            style={{background:`linear-gradient(135deg,${PURPLE},#c471ed)`,color:"#fff",padding:"12px 28px",borderRadius:28,fontWeight:800,fontSize:14,boxShadow:`0 4px 16px ${PURPLE}44`}}>
                            처음으로
                        </button>
                    )}
                </div>

                {/* ── 뒤로 ── */}
                {step>0&&step<4&&<button className="back-btn" onClick={()=>setStep(step-1)}>← 뒤로 가기</button>}

                {/* ── STEP 0: 무드 선택 ── */}
                {step===0 && (
                    <div className="mood-grid">
                        <div style={{textAlign:"center",marginBottom:24}}>
                            <h2 style={{fontSize:34,fontWeight:900,margin:"0 0 6px",letterSpacing:"-0.4px"}}>오늘의 색을 알려주세요</h2>
                            <p style={{fontSize:12,letterSpacing:"0.25em",color:"#999",margin:0,fontFamily:"'Outfit',sans-serif"}}>WHAT'S YOUR MOOD?</p>
                        </div>
                        <div className="mood-row">
                            {["chill","happy","romance"].map(m=>(
                                <button key={m} className="mood-card" style={MOOD_STYLE[m]} onClick={()=>{setMood(m);setStep(1);}}>
                                    <img src={`./${m}.png`}/>
                                </button>
                            ))}
                        </div>
                        <div className="mood-row">
                            {["sad","study","party","sleep"].map(m=>(
                                <button key={m} className="mood-card" style={MOOD_STYLE[m]} onClick={()=>{setMood(m);setStep(1);}}>
                                    <img src={`./${m}.png`}/>
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                {/* ── STEP 1: 군집 선택 ── */}
                {step===1 && mood && (
                    <div>
                        <div style={{textAlign:"center",marginBottom:32}}>
                            <p style={{fontSize:13,color:"#aaa",margin:"0 0 6px",letterSpacing:"0.05em",fontWeight:500}}>어떤 느낌을 원하시나요?</p>
                            <h1 style={{fontSize:30,fontWeight:900,margin:0,color:accent}}>오늘의 MOOD를 골라보세요.</h1>
                        </div>
                        <div style={{display:"grid",gridTemplateColumns:`repeat(${clusters.length},1fr)`,gap:16}}>
                            {clusters.map(cl=>(
                                <button key={cl.id} className="cluster-card"
                                    style={{borderColor:"#E5DED9",boxShadow:"0 2px 8px rgba(0,0,0,0.05)"}}
                                    onMouseEnter={e=>hoverOn(e.currentTarget,accent)}
                                    onMouseLeave={e=>hoverOff(e.currentTarget)}
                                    onClick={()=>{setCId(cl.id);setStep(2);}}>
                                    {/* 해시태그 한 줄 */}
                                    <div className="tag-row">
                                        {cl.tags.map((tag,i)=>(
                                            <span key={i} className="hashtag" style={{color:accent}}>{tag}</span>
                                        ))}
                                    </div>
                                    {/* 레이더 */}
                                    <div style={{display:"flex",justifyContent:"center",overflow:"visible",padding:"8px 0"}}>
                                        <RadarChart means={cl.avg} accent={accent}/>
                                    </div>
                                    {/* 피처 바 */}
                                    <FeatBars means={cl.avg} accent={accent}/>
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                {/* ── STEP 2: 취향 질문 ── */}
                {step===2 && qFeat && (
                    <div className="center-screen">
                        <h1 className="center-title">조금 더 취향을 좁혀볼까요?</h1>
                        <p className="center-sub">당신에 대해 더 알고 싶어요</p>
                        <div className="center-opts">
                            {[{label:FEAT_Q[qFeat].hi,icon:"▲",s:'high'},{label:FEAT_Q[qFeat].lo,icon:"▼",s:'low'}].map((opt,i)=>(
                                <button key={i} className="q-btn"
                                    onMouseEnter={e=>{e.currentTarget.style.borderColor=PURPLE;e.currentTarget.style.boxShadow=`0 0 0 2px ${PURPLE}33`;}}
                                    onMouseLeave={e=>{e.currentTarget.style.borderColor='#DDD';e.currentTarget.style.boxShadow='none';}}
                                    onClick={()=>{setSide(opt.s);setStep(3);}}>
                                    <div className="q-icon" style={{background:PURPLE_LIGHT,color:PURPLE}}>{opt.icon}</div>
                                    <span>{opt.label}</span>
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                {/* ── STEP 3: 시드 선택 ── */}
                {step===3 && (
                    <div className="center-screen">
                        <h1 className="center-title">조금 더 취향을 좁혀볼까요?</h1>
                        <p className="center-sub">어떤 음악을 기준으로 시작할까요?</p>
                        <div className="center-opts">
                            {[
                                {label:"⭐ 대중성 높은 곡으로 시작하기",name:popSeed[0],artist:popSeed[1],pref:'pop'},
                                {label:"🎯 내 취향에 딱 맞는 곡으로 시작하기",name:simSeed[0],artist:simSeed[1],pref:'sim'}
                            ].map((opt,i)=>(
                                <button key={i} className="seed-btn"
                                    onMouseEnter={e=>{e.currentTarget.style.borderColor=PURPLE;e.currentTarget.style.boxShadow=`0 0 0 2px ${PURPLE}33`;}}
                                    onMouseLeave={e=>{e.currentTarget.style.borderColor='#DDD';e.currentTarget.style.boxShadow='none';}}
                                    onClick={()=>generatePlaylist(opt.pref)}>
                                    <span className="seed-label" style={{color:PURPLE}}>{opt.label}</span>
                                    <span className="seed-name">{opt.name}</span>
                                    <span className="seed-artist">{opt.artist}</span>
                                </button>
                            ))}
                        </div>
                    </div>
                )}

                {/* ── STEP 4: 플레이리스트 (전부 퍼플 고정) ── */}
                {step===4 && (
                    <div style={{display:"flex",gap:20,alignItems:"flex-start",flexWrap:"wrap"}}>
                        <div style={{flex:"1 1 300px",position:"sticky",top:20}}>
                            <iframe
                                src={`https://open.spotify.com/embed/track/${playlist[nowPlaying]?.track_id}?utm_source=generator`}
                                width="100%" height="352" frameBorder="0" allowFullScreen
                                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                                loading="lazy" style={{borderRadius:16,boxShadow:"0 10px 30px rgba(0,0,0,0.1)"}}/>
                        </div>
                        <div style={{flex:"2 1 500px",display:"flex",flexDirection:"column",gap:10}}>
                            {playlist.map((s,i)=>(
                                <div key={i} onClick={()=>setNow(i)}
                                    style={{padding:"16px 20px",background:i===nowPlaying?PURPLE_LIGHT:"#FFFFFF",
                                        border:"1.5px solid",borderColor:i===nowPlaying?PURPLE:"#E5DED9",
                                        borderRadius:16,display:"grid",gridTemplateColumns:"50px 1fr",
                                        alignItems:"center",cursor:"pointer",transition:"all 0.18s",
                                        boxShadow:i===nowPlaying?`0 2px 12px ${PURPLE}22`:"none"}}>
                                    <div style={{width:40,height:40,background:i===nowPlaying?`${PURPLE}22`:"#F0EAE7",borderRadius:8,display:"flex",alignItems:"center",justifyContent:"center",color:PURPLE,fontWeight:900,fontSize:14}}>
                                        {i===nowPlaying?"▶":i+1}
                                    </div>
                                    <div>
                                        <div style={{display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:6}}>
                                            <div>
                                                <div style={{fontWeight:700,color:i===nowPlaying?PURPLE:"#131313",fontSize:15}}>{s.track_name}</div>
                                                <div style={{fontSize:12,color:"#999",marginTop:1}}>{s.artists}</div>
                                            </div>
                                            <div style={{fontSize:11,color:PURPLE,fontWeight:700,whiteSpace:"nowrap",marginLeft:12}}>
                                                {i===0?"대표곡":`${s.similarity}% 유사`}
                                            </div>
                                        </div>
                                        <div className="pl-bar-bg">
                                            <div className="pl-bar-fill" style={{width:`${s.similarity}%`}}/>
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                )}
            </>)}
        </div>
    );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
